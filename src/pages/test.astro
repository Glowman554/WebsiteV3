---
import Layout from '../components/Layout.astro';
import ModelViewer from '../components/ModelViewer';

export const prerender = false;

const props = {
    configuration: {
        visibility: {},
        rotation: {
            upperarm_r: {
                x: 0,
                y: 0,
                z: -55,
            },
            forearm_r: {
                x: 0,
                y: 0,
                z: -20,
            },

            upperarm_l: {
                x: 0,
                y: 0,
                z: 55,
            },
            forearm_l: {
                x: 0,
                y: 0,
                z: 20,
            },
        },
        blendShapes: {
            Bigger: 1,
            happy: 1,
            tongue: 1,
            hideGoggles: 1,
            noLeash: 1,
        },
    },
    href: '/Whirly.glb',
    showSkeleton: false,
};
---

<Layout title="Toxic fox - About me" description="Learn more about me.">
    <ModelViewer client:only href={props.href} configuration={props.configuration} showSkeleton={props.showSkeleton} />
</Layout>
